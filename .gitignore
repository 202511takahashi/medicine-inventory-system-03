# Java / Maven build outputs
# Generated files do not need Git management.
target/
*.class
*.jar

# Keep existing exceptions for unusual src-side build folders
!**/src/main/**/target/
!**/src/test/**/target/

# Local database files
# H2 or other local DB files are environment-specific, so ignore them.
data/*.mv.db
data/*.lock.db
*.db
*.mv.db
*.lock.db

# Maven Wrapper
# Keep the existing project rule as-is.
.mvn/wrapper/maven-wrapper.jar

# IDE and editor files
# Personal editor settings should not be committed.
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.vscode/

# STS
.apt_generated
.factorypath
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# OS generated files
.DS_Store
Thumbs.db